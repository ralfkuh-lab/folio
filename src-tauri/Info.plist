<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSScreenCaptureUsageDescription</key>
    <string>Folio benötigt Bildschirmaufnahme-Zugriff für die Automation-API (GET /screenshot).</string>

    <!-- Überschreibt Tauris CFBundleDocumentTypes, das kein
         CFBundleTypeIconFile serialisiert. Nur Extensions, kein
         LSItemContentTypes (undeklarierte UTIs wie net.daringfireball.markdown
         lassen macOS den ganzen Eintrag ignorieren). -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>md</string>
                <string>markdown</string>
            </array>
            <key>CFBundleTypeIconFile</key>
            <string>icon</string>
            <key>CFBundleTypeName</key>
            <string>Markdown Document</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
        </dict>
    </array>
</dict>
</plist>
